<body>

<div id="game-container">
    <div class="header">
        <span id="level-title">第 1 关</span>
        <div id="remain-count">等车旅客: 0</div>
        <div class="coin-box">🪙 <span id="coin-count">120</span></div>
    </div>

    <div class="top-zone">
        <div class="track-container" id="track-container">
            <div class="track-center">
                🚌 环形候车区<br>
                <span id="live-info" style="font-size:10px; color:#718096">有车位即可上车</span>
            </div>
            </div>
        
        <div class="parking-slots" id="parking-slots">
            </div>
    </div>

    <div class="board-zone">
        <div class="grid-board" id="grid-board">
            <div class="grid-bg-line" id="grid-bg-line"></div>
            </div>
    </div>

    <div class="dock-zone">
        <button class="btn-prop" onclick="triggerProp('shuffle')">
            <div class="icon">🔄</div>
            <span>死局重排</span>
        </button>
        <button class="btn-prop" onclick="triggerProp('clearSlot')">
            <div class="icon">🔨</div>
            <span>清空车位</span>
        </button>
        <button class="btn-prop" onclick="triggerProp('bonusSlot')">
            <div class="icon">🅿️</div>
            <span>临时车位</span>
        </button>
    </div>

    <div class="win-overlay" id="win-overlay">
        <div class="win-box">
            <h2 style="color: var(--color-yellow); margin-bottom: 8px;">🌟 顺利通关 🌟</h2>
            <p>成功清空候车轨道！金币 +50</p>
            <button class="btn-next" onclick="loadNextLevel()">下一关</button>
        </div>
    </div>
</div>

<script>
    // --- 关卡配置 (大幅增加了每关的旅客总数，避免死局) ---
    const LEVELS = [
        {
            level: 1,
            // 轨道上同时游荡超多旅客，任何颜色的车停进去都能直接吸纳走对应小人
            passengers: ['red','red','red','blue','blue','blue','green','green','green','purple','purple','purple','yellow','yellow'],
            vehicles: [
                { id: 1, color: 'red',    dir: 'right',     row: 0, col: 0, size: 2 },
                { id: 2, color: 'blue',   dir: 'down',      row: 0, col: 3, size: 2 },
                { id: 3, color: 'green',  dir: 'down-right',row: 2, col: 1, size: 2 }, // 斜向车
                { id: 4, color: 'purple', dir: 'left',      row: 4, col: 4, size: 2 },
                { id: 5, color: 'yellow', dir: 'up-left',   row: 5, col: 2, size: 2 }, // 斜向车
                { id: 6, color: 'blue',   dir: 'up',        row: 4, col: 0, size: 2 }
            ]
        },
        {
            level: 2,
            passengers: ['pink','pink','pink','pink','yellow','yellow','yellow','green','green','green','blue','blue','blue','red','red'],
            vehicles: [
                { id: 1, color: 'pink',   dir: 'right',     row: 1, col: 1, size: 3 }, // 中型车
                { id: 2, color: 'yellow', dir: 'down-left', row: 0, col: 4, size: 2 },
                { id: 3, color: 'green',  dir: 'up',        row: 4, col: 5, size: 2 },
                { id: 4, color: 'blue',   dir: 'left',      row: 5, col: 3, size: 2 },
                { id: 5, color: 'red',    dir: 'down',      row: 2, col: 0, size: 2 },
                { id: 6, color: 'pink',   dir: 'up-right',  row: 3, col: 2, size: 2 }
            ]
        }
    ];

    // --- 8方向步进矢量及角度映射 ---
    const DIR_DATA = {
        'up':         { dr: -1, dc:  0, angle: 0 },
        'up-right':   { dr: -1, dc:  1, angle: 45 },
        'right':      { dr:  0, dc:  1, angle: 90 },
        'down-right': { dr:  1, dc:  1, angle: 135 },
        'down':       { dr:  1, dc:  0, angle: 180 },
        'down-left':  { dr:  1, dc: -1, angle: 225 },
        'left':       { dr:  0, dc: -1, angle: 270 },
        'up-left':    { dr: -1, dc: -1, angle: 315 }
    };

    let currentLevelIdx = 0;
    let coins = 120;
    let maxSlots = 2; // 初始2个车位
    let trackPassengers = []; // 轨道上的乘客实例数组
    let vehicles = [];
    let parkedSlots = [null, null, null, null, null]; // 最多5个车位
    let grid = [];
    const GRID_SIZE = 6;
    const CELL_PX = 55;
    let animationFrameId = null;

    // --- 初始化 ---
    function init() {
        const bgLine = document.getElementById('grid-bg-line');
        bgLine.innerHTML = '';
        for(let i=0; i<GRID_SIZE*GRID_SIZE; i++) {
            const cell = document.createElement('div');
            cell.className = 'grid-cell-deco';
            bgLine.appendChild(cell);
        }
        loadLevel(currentLevelIdx);
        // 启动椭圆轨道运动渲染时钟
        if (animationFrameId) cancelAnimationFrame(animationFrameId);
        updateTrackPhysics();
    }

    // --- 加载关卡 ---
    function loadLevel(idx) {
        const data = LEVELS[idx % LEVELS.length];
        document.getElementById('level-title').innerText = `第 ${data.level} 关`;
        document.getElementById('coin-count').innerText = coins;
        document.getElementById('win-overlay').style.display = 'none';

        vehicles = data.vehicles.map(v => ({
            ...v,
            capacity: v.size,
            boarded: 0,
            status: 'board' 
        }));

        parkedSlots = [null, null, null, null, null];

        // 初始化跑动乘客数据 (均匀分布在椭圆轨道的不同初始弧度角上)
        trackPassengers = data.passengers.map((color, i) => ({
            id: i,
            color: color,
            angle: (i * (Math.PI * 2 / data.passengers.length)) // 均分角度
        }));

        buildGridMap();
        renderVehicles();
        renderSlots();
        updatePassengerCountUI();
    }

    function updatePassengerCountUI() {
        document.getElementById('remain-count').innerText = `等车旅客: ${trackPassengers.length}`;
    }

    // --- 构建底层网格矩阵 (精确处理斜向和直线多格占用) ---
    function buildGridMap() {
        grid = Array(GRID_SIZE).fill(null).map(() => Array(GRID_SIZE).fill(0));
        vehicles.forEach(v => {
            if (v.status !== 'board') return;
            const { dr, dc } = DIR_DATA[v.dir];
            for (let i = 0; i < v.size; i++) {
                const r = v.row + i * dr;
                const c = v.col + i * dc;
                if (r >= 0 && r < GRID_SIZE && c >= 0 && c < GRID_SIZE) {
                    grid[r][c] = v.id;
                }
            }
        });
    }

    // --- 渲染：车位 ---
    function renderSlots() {
        const slotsEl = document.getElementById('parking-slots');
        slotsEl.innerHTML = '';
        for(let i=0; i<5; i++) {
            const slot = document.createElement('div');
            if (i >= maxSlots) {
                slot.className = 'slot locked';
                slot.innerHTML = `<div>🔒</div><div style="font-size:9px">50金币</div>`;
                slot.onclick = () => unlockSlot(i);
            } else {
                slot.className = 'slot';
                const car = parkedSlots[i];
                if (car) {
                    slot.innerHTML = `
                        <div class="bg-${car.color}" style="width:100%; height:100%; border-radius:6px; display:flex; flex-direction:column; justify-content:center; align-items:center; color:white; font-weight:bold;">
                            <span style="font-size:14px">🚌</span>
                            <span style="font-size:11px">${car.boarded}/${car.capacity}</span>
                        </div>
                    `;
                } else {
                    slot.innerHTML = `<span style="color:rgba(255,255,255,0.4)">车位 ${i+1}</span>`;
                }
            }
            slotsEl.appendChild(slot);
        }
    }

    function unlockSlot(i) {
        if (coins >= 50) {
            coins -= 50;
            maxSlots++;
            document.getElementById('coin-count').innerText = coins;
            renderSlots();
            checkTrackBoarding();
        } else {
            alert("金币不足！需要50金币。");
        }
    }

    // --- 渲染：盘面车辆 ---
    function renderVehicles() {
        const board = document.getElementById('grid-board');
        document.querySelectorAll('.vehicle').forEach(el => el.remove());

        vehicles.forEach(v => {
            if (v.status !== 'board') return;
            const carEl = document.createElement('div');
            carEl.className = `vehicle bg-${v.color}`;
            carEl.id = `vehicle-${v.id}`;

            // 为了完美适配8方向的纯视觉旋转，统一将车按行进方向拉伸，并通过 transform 旋转
            // 这样无论直行还是斜行，车头永远朝向箭头方向
            carEl.style.width = `${CELL_PX * v.size - 6}px`;
            carEl.style.height = `${CELL_PX - 6}px`;

            // 计算中心锚点定位
            const { dr, dc, angle } = DIR_DATA[v.dir];
            // 计算车身的物理中心点格子位置
            const centerR = v.row + ((v.size - 1) * dr) / 2;
            const centerC = v.col + ((v.size - 1) * dc) / 2;

            carEl.style.left = `${centerC * CELL_PX + CELL_PX/2 - (CELL_PX * v.size)/2 + 3}px`;
            carEl.style.top = `${centerR * CELL_PX + CELL_PX/2 - CELL_PX/2 + 3}px`;
            carEl.style.transform = `rotate(${angle - 90}deg)`; // 默认车身是水平右向的，减去90度修正为正北朝向基准

            const ui = document.createElement('div');
            ui.className = 'vehicle-ui';
            // 抵消外层旋转让文字和箭头保持正向
            ui.style.transform = `rotate(${-(angle - 90)}deg)`;
            ui.innerHTML = `<div class="arrow">➔</div><div class="capacity">${v.capacity}人</div>`;
            carEl.appendChild(ui);

            carEl.onclick = () => driveVehicle(v);
            board.appendChild(carEl);
        });
    }

    // --- 核心改动：点击直接一冲到底（撞墙停下或直接出库） ---
    function driveVehicle(v) {
        const { dr, dc } = DIR_DATA[v.dir];
        let currentOccupied = [];
        for (let i = 0; i < v.size; i++) {
            currentOccupied.push({ r: v.row + i * dr, c: v.col + i * dc });
        }

        let finalSteps = 0;
        let canExitEntirely = true;

        // 沿行进矢量方向一步步向前试探
        while (true) {
            let nextSteps = finalSteps + 1;
            let hitsObstacle = false;
            let outOfBoundsCount = 0;

            for (let i = 0; i < v.size; i++) {
                let nr = currentOccupied[i].r + nextSteps * dr;
                let nc = currentOccupied[i].c + nextSteps * dc;

                // 判断这一格是否出界
                if (nr < 0 || nr >= GRID_SIZE || nc < 0 || nc >= GRID_SIZE) {
                    outOfBoundsCount++;
                    continue;
                }
                // 判断是否撞到了非自身的车辆
                if (grid[nr][nc] !== 0 && grid[nr][nc] !== v.id) {
                    hitsObstacle = true;
                    break;
                }
            }

            if (hitsObstacle) {
                canExitEntirely = false;
                break; // 撞到东西了，退回上一步能停的位置
            }

            // 如果车身的所有格子都已经出界，说明完全开出去了
            if (outOfBoundsCount === v.size) {
                break;
            }

            finalSteps = nextSteps;
        }

        const el = document.getElementById(`vehicle-${v.id}`);

        if (canExitEntirely) {
            // 1. 成功开出停车场：寻找空车位
            let freeSlotIdx = parkedSlots.findIndex((s, idx) => s === null && idx < maxSlots);
            if (freeSlotIdx === -1) {
                // 车位满了，无法开出
                alert("车位已满！请先消除或清空车位。");
                return;
            }

            v.status = 'parked';
            parkedSlots[freeSlotIdx] = v;

            // 冲出边界动画
            el.style.left = `${parseFloat(carElLeft(v, finalSteps + 4, dc))}px`;
            el.style.top = `${parseFloat(carElTop(v, finalSteps + 4, dr))}px`;
            el.style.opacity = '0';

            setTimeout(() => {
                buildGridMap();
                renderVehicles();
                renderSlots();
                checkTrackBoarding(); // 触发上车检测
            }, 250);

        } else {
            // 2. 未能开出：顶到最前方车辆后面停下，更新地图网格占用
            if (finalSteps === 0) {
                // 原地完全动不了，播放抖动动效
                el.style.transform += ' scale(0.95)';
                setTimeout(() => renderVehicles(), 100);
                return;
            }

            v.row = v.row + finalSteps * dr;
            v.col = v.col + finalSteps * dc;

            // 播放滑行平移
            buildGridMap(); // 重新计算全局网格
            renderVehicles();
        }
    }

    function carElLeft(v, steps, dc) { return (v.col + steps * dc) * CELL_PX; }
    function carElTop(v, steps, dr) { return (v.row + steps * dr) * CELL_PX; }

    // --- 核心改动：椭圆轨道旅客走动与动态匹配机制 ---
    function updateTrackPhysics() {
        const container = document.getElementById('track-container');
        // 移除旧小人DOM
        document.querySelectorAll('.track-passenger').forEach(el => el.remove());

        // 椭圆长短轴参数 (适配最高480px容器)
        const rx = 190; 
        const ry = 40;  
        const cx = 225; // 中心点X
        const cy = 55;  // 中心点Y

        trackPassengers.forEach(p => {
            // 每一帧递增弧度，控制滚动速度
            p.angle += 0.008; 
            
            // 椭圆参数方程计算坐标
            const x = cx + rx * Math.cos(p.angle);
            const y = cy + ry * Math.sin(p.angle);

            const pEl = document.createElement('div');
            pEl.className = `track-passenger bg-${p.color}`;
            pEl.style.left = `${x}px`;
            pEl.style.top = `${y}px`;
            container.appendChild(pEl);
        });

        animationFrameId = requestAnimationFrame(updateTrackPhysics);
    }

    // 检测车位里的车辆并从轨道上任意位置吸纳对应色小人
    function checkTrackBoarding() {
        let stateChanged = false;

        for (let i = 0; i < maxSlots; i++) {
            let car = parkedSlots[i];
            if (!car) continue;

            // 只要轨道里还存有跟这辆车颜色一样的小人，就直接吸纳上车
            while (car.boarded < car.capacity) {
                let pIdx = trackPassengers.findIndex(p => p.color === car.color);
                if (pIdx !== -1) {
                    // 从环形轨道中剥离该小人
                    trackPassengers.splice(pIdx, 1);
                    car.boarded++;
                    stateChanged = true;

                    // 满载直接开走，释放车位
                    if (car.boarded >= car.capacity) {
                        car.status = 'gone';
                        parkedSlots[i] = null;
                        break;
                    }
                } else {
                    // 轨道上没有该色小人了
                    break;
                }
            }
        }

        if (stateChanged) {
            renderSlots();
            updatePassengerCountUI();
            checkWinCondition();
        }
    }

    // --- 胜负判定 ---
    function checkWinCondition() {
        if (trackPassengers.length === 0) {
            setTimeout(() => {
                document.getElementById('win-overlay').style.display = 'flex';
                coins += 50;
                document.getElementById('coin-count').innerText = coins;
            }, 400);
        }
    }

    function loadNextLevel() {
        currentLevelIdx++;
        loadLevel(currentLevelIdx);
    }

    // --- 道具管理系统 ---
    function triggerProp(type) {
        if (type === 'shuffle') {
            // 死局随机重排列组合 (直接重置本关车子初始位置)
            alert("✨ 已为您刷新本关车辆布局！");
            loadLevel(currentLevelIdx);
        } else if (type === 'clearSlot') {
            // 🔨 强行清空车位上堵塞的第一辆车
            let idx = parkedSlots.findIndex(s => s !== null);
            if (idx !== -1) {
                parkedSlots[idx] = null;
                renderSlots();
                checkTrackBoarding();
            } else {
                alert("当前没有车辆占用车位。");
            }
        } else if (type === 'bonusSlot') {
            // 开放临时车位
            if (maxSlots < 5) {
                maxSlots++;
                renderSlots();
                checkTrackBoarding();
            } else {
                alert("已达到最大车位上限！");
            }
        }
    }

    window.onload = init;
</script>
</body>
</html>

```
# 停车场出口游戏 - 完整需求文档

## 游戏概述
停车场出口解谜游戏。玩家把停车场里的车按箭头方向开出停车场，进入椭圆形候车轨道旁的停车位，接走同色乘客，清空候车区通关。

---

## 一、核心玩法

### 布局
- 多辆车放置在盘面上，每辆车只有一个方向箭头(8方向之一)
- 车只能沿箭头方向前进，不能倒车，点一下就发车
- 车开出停车场任意边缘（没有固定出口）

### 候车系统（上方区域）
- **椭圆形轨道**：位于棋盘上方，小人在轨道上沿着通道转圈走
- **候车池**：不同颜色不同数量的小人在轨道上排队
- **待候车池**：左上方显示等待进入轨道的小人队列
- **上车动画**：小人从椭圆形左下角走向停车位对应颜色的车

### 停车位
- 位于椭圆形轨道旁边（不在下方）
- 初始解锁2个停车位
- 金币解锁额外车位，最多5个
- 车进入停车位后接同色乘客，坐满发车释放车位
- 如果车颜色与当前上车颜色不匹配→在车位等待

### 通关条件
- 候车池清空 → 通关
- 死局（无车可动+还有人）→ 自动随机重排

---

## 二、车辆系统

### 车辆属性
| 属性 | 说明 |
|------|------|
| 方向 | 8方向(上下左右+斜4向)，只能前进 |
| 颜色 | 红蓝绿黄紫橙粉，随关卡增多 |
| 长度 | 小车2格 / 中车3格 / 大巴4格 |
| 容量 | 小车2人 / 中车3人 / 大巴4人 |
| 状态 | 在停车场/在停车位/已发车 |

### 交互方式
- 点击车辆选中 → 高亮可滑行路径（虚线+光点）
- **手动拖动**车辆沿箭头方向控制走几格（拖多远走多远）
- 车到棋盘边缘 → 进入停车位

### 碰撞规则
- 车头正前方检测：有车/出界
- 斜向路径有自己车时拦住，不是对角线没车就直接通过
- 被阻挡车辆半透明
- **只有4方向（上下左右），移除斜向格子**

---

## 三、关卡系统

### 生成方式
- 程序化随机生成
- 死局自动重排（最多100次尝试）
- 可解性验证（DFS求解器，30步深度）

### 难度曲线
- 难度逐渐上升

---

## 四、经济系统

- 通关发金币
- 商店购买：
  - 临时停车位（解锁额外车位，金币支付）
  - 刷新道具（重置车辆位置）
  - 硬消道具（移除一辆车）
  - 磁铁道具
  - 提示道具
- 道具次数用完置灰

